{
  "name": "gestao-autopecas-backend",
  "version": "2.0.0",
  "description": "ERP SaaS multi-tenant — backend Node.js + Express + Prisma",
  "private": true,
  "engines": { "node": ">=20" },
  "scripts": {
    "dev":                  "nodemon server.js",
    "start":                "node server.js",
    "db:generate:master":   "prisma generate --schema=prisma/master/schema.prisma",
    "db:generate:tenant":   "prisma generate --schema=prisma/tenant/schema.prisma",
    "db:generate":          "npm run db:generate:master && npm run db:generate:tenant",
    "db:migrate:master":    "prisma migrate deploy --schema=prisma/master/schema.prisma",
    "db:seed":              "node prisma/seed.js",
    "db:setup":             "npm run db:generate && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs":        "^2.4.3",
    "cors":            "^2.8.5",
    "dotenv":          "^16.3.1",
    "express":         "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":          "^7.1.0",
    "jsonwebtoken":    "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma":  "^5.7.0"
  }
}
