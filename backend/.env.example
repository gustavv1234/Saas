# =============================================================================
# ERP SaaS — Gestão Autopeças | Variáveis de Ambiente
# Copie para .env e preencha com valores reais.
# NUNCA commite o .env real.
# =============================================================================

# Banco de dados master (tenants + usuários master)
MASTER_DATABASE_URL="file:./data/master.db"

# DATABASE_URL é usado pelo Prisma CLI para migrations do schema tenant
# Em runtime, cada tenant tem sua URL gerada automaticamente pelo factory.
DATABASE_URL="file:./data/tenant_demo.db"

# JWT — string longa e aleatória. Gere com:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="substitua-por-uma-string-longa-aleatoria-e-segura"
JWT_EXPIRES_IN="8h"

# Servidor
PORT=3000
NODE_ENV="development"

# CORS — em produção, especifique a URL real do frontend
CORS_ORIGIN="http://localhost:3000"

# Rate limiting (login)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Senhas iniciais do seed (use apenas no primeiro setup)
SEED_MASTER_PASSWORD="troque-esta-senha-master"
SEED_ADMIN_PASSWORD="troque-esta-senha-admin"
