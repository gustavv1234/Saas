# =============================================================================
# Gestão Autopeças — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o .env real. Apenas este .env.example vai ao repositório.
# =============================================================================

# Banco de dados
# Local / Docker (SQLite):
DATABASE_URL="file:./data/gestao-autopecas.db"
# Para PostgreSQL (VPS / futura migração), troque por:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gestao_autopecas"

# JWT — use uma string longa, aleatória e nunca compartilhada.
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="substitua-por-uma-string-longa-aleatoria-e-segura"
JWT_EXPIRES_IN="8h"

# Servidor
PORT=3000
NODE_ENV="development"

# CORS — em produção, especifique a URL real do frontend
# Ex: "http://192.168.1.100" ou "https://meudominio.com"
CORS_ORIGIN="http://localhost:3000"

# Rate limiting (autenticação)
# Janela de tempo em ms (padrão: 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
# Máximo de tentativas por IP na janela (padrão: 10)
RATE_LIMIT_MAX=10

# Senha do usuário admin inicial (usada apenas pelo seed)
# Troque por uma senha forte. O admin deve trocar após o primeiro login.
SEED_ADMIN_PASSWORD="troque-esta-senha-no-primeiro-acesso"
